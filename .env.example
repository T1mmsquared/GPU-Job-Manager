# Postgres (used by the Postgres container on first boot)
POSTGRES_USER=gpu_jobs
POSTGRES_PASSWORD=changeme
POSTGRES_DB=gpu_jobs

# App connection string (used by API + worker)
DATABASE_URL=postgresql://gpu_jobs:changeme@db:5432/gpu_jobs

# Redis/Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

#JWT Authentication
SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

