# Use LF line endings for all shell scripts
*.sh text eol=lf

# Optional: enforce LF for common project files
*.py  text eol=lf
*.txt text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Keep binary files untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
